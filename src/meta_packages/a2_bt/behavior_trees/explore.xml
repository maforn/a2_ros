<root BTCPP_format="4">
  <!--
    Simple exploration: stand up, explore, go back to hardcoded home position.

    Usage:
      a2 bt tree explore
  -->
  <BehaviorTree ID="Explore">
    <Sequence>

      <!-- Boot FSM -->
      <SetMode mode="2" wait_for_sec="3.0" />
      <SetMode mode="3" wait_for_sec="3.0" />
      <SetMode mode="4" wait_for_sec="1.0" />

      <!-- Hardcoded home position (map origin) -->
      <CreatePose x="0.0" y="0.0" yaw="0.0" frame_id="map" pose="{home_pose}" />

      <!-- Start exploration -->
      <StartExploration start_topic="/start_exploration" />

      <!-- Wait for TARE to finish (or timeout) -->
      <ForceSuccess>
        <WaitForExplorationFinish
          finish_topic="exploration_finish"
          status_topic="bt/exploration_status"
          timeout_sec="300.0" />
      </ForceSuccess>

      <!-- Stop TARE and pathFollower -->
      <StopExploration />
      <StopMovement />

      <!-- Resume movement and navigate home -->
      <StopMovement data="0" />
      <ForceSuccess>
        <NavigateToPose
          goal_pose="{home_pose}"
          frame_id="map"
          goal_topic="/goal_point"
          timeout_sec="120.0" />
      </ForceSuccess>

      <!-- Sit -->
      <SetMode mode="1" wait_for_sec="3.0" />

    </Sequence>
  </BehaviorTree>
</root>
