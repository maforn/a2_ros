<root BTCPP_format="4">
  <!--
    Autonomous exploration mission with home return on timeout.

    Cases:
      - WaitForExplorationFinish SUCCESS (TARE done)  → mission complete.
      - WaitForExplorationFinish FAILURE (timeout)    → NavigateToPose returns robot to home.

    Usage:
      ros2 action send_goal /bt_action_server behaviortree_ros2/action/ExecuteTree \
        "{target_tree: 'Explore', payload: 'explore.xml'}"

    Live status:
      ros2 topic echo /bt/exploration_status
  -->
  <BehaviorTree ID="Explore">
    <Sequence>

      <StartExploration start_topic="/start_exploration" />

      <Fallback>

        <!-- Normal case: wait for TARE to finish exploration -->
        <WaitForExplorationFinish
          finish_topic="exploration_finish"
          status_topic="bt/exploration_status"
          timeout_sec="300.0" />

        <!-- Timeout fallback: navigate back to home -->
        <NavigateToPose
          goal_x="0.0"
          goal_y="0.0"
          frame_id="map"
          goal_topic="/goal_point"
          timeout_sec="120.0" />

      </Fallback>

    </Sequence>
  </BehaviorTree>
</root>
