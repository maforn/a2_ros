<root BTCPP_format="4">
  <!--
    Autonomous exploration mission with object detection, home return, and map save.

    Flow:
      1. SavePose                — capture robot's current pose from /state_estimation as {home_pose}
      2. detection_mapper/start  — reset and start accumulating detections
      3. StartExploration        — trigger ALO via /start_exploration
      4. WaitForExplorationFinish — block until ALO reports done (or timeout)
         (ForceSuccess absorbs timeout so the rest always runs)
      5. StopExploration         — stop ALO waypoints
      6. StopMovement            — halt pathFollower
      7. detection_mapper/stop   — stop accumulating detections
      8. detection_mapper/save_csv — persist detections to CSV
      9. StopMovement(0)         — resume movement for far_planner
      10. NavigateToPose         — return to {home_pose}
      11. save_map_node          — save RESPLE map
      12. detection_mapper/save_csv (second call) — ensure CSV is flushed after nav

    Usage:
      a2 bt tree challenge
  -->
  <BehaviorTree ID="Challenge">
    <Sequence>

      <!-- 1. Capture current pose from /state_estimation as home position -->
      <SavePose pose="{home_pose}" />

      <!-- 2. Move 1 m forward from start position -->
      <!-- <OffsetPose input_pose="{home_pose}" distance_x="1.0" distance_y="0.0" output_pose="{forward_pose}" />
      <NavigateToPose
        goal_pose="{forward_pose}"
        frame_id="map"
        goal_topic="/goal_point"
        timeout_sec="30.0" /> -->

      <!-- 3. Reset detection accumulator and start collecting -->
      <CallTriggerService service_name="detection_mapper/start" />

      <!-- 3. Trigger ALO exploration -->
      <StartExploration start_topic="/start_exploration" />

      <!-- 4. Wait for exploration to finish or time out -->
      <ForceSuccess>
        <WaitForExplorationFinish
          finish_topic="exploration_finish"
          status_topic="bt/exploration_status"
          timeout_sec="300.0" />
      </ForceSuccess>

      <!-- 5-6. Stop ALO waypoints and halt pathFollower -->
      <StopExploration />
      <StopMovement />

      <!-- 7-8. Stop detection mapper and persist detections to CSV -->
      <CallTriggerService service_name="detection_mapper/stop" />
      <ForceSuccess>
        <CallTriggerService service_name="detection_mapper/save_csv" />
      </ForceSuccess>

      <!-- 9. Resume movement so far_planner can drive the robot -->
      <StopMovement data="0" />

      <!-- 10. Return home. ForceSuccess absorbs nav failure. -->
      <ForceSuccess>
        <NavigateToPose
          goal_pose="{home_pose}"
          frame_id="map"
          goal_topic="/goal_point"
          timeout_sec="120.0" />
      </ForceSuccess>

      <!-- 11. Save RESPLE map -->
      <ForceSuccess>
        <CallEmptyService service_name="save_map_node" timeout_sec="10.0" />
      </ForceSuccess>

      <!-- 12. Final CSV flush after navigation (catches any detections during home return) -->
      <ForceSuccess>
        <CallTriggerService service_name="detection_mapper/save_csv" />
      </ForceSuccess>

    </Sequence>
  </BehaviorTree>
</root>
