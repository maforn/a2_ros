<root BTCPP_format="4">
  <!--
    Reset DLIO odometry and map, then navigate a square loop.

    Steps:
      1. Reset DLIO odom  (dlio/reset)
      2. Reset DLIO map   (dlio/reset_map)
      3. Navigate P1→P2→P3→P4 in a loop (same square as NavigateLoop)
  -->
  <BehaviorTree ID="DlioResetLoop">
    <Sequence>
      <!-- Clear DLIO state before starting -->
      <CallTriggerService service_name="dlio/reset"     />
      <CallTriggerService service_name="dlio/reset_map" />

      <!-- Square navigation loop -->
      <Repeat num_cycles="20">
        <Sequence>
          <CreatePose x="2.0"  y="1.0"  yaw="0.0" frame_id="map" pose="{goal_pose}" />
          <NavigateToPose goal_pose="{goal_pose}" frame_id="map" goal_topic="/goal_point" timeout_sec="60.0" />

          <CreatePose x="2.0"  y="-1.0" yaw="0.0" frame_id="map" pose="{goal_pose}" />
          <NavigateToPose goal_pose="{goal_pose}" frame_id="map" goal_topic="/goal_point" timeout_sec="60.0" />

          <CreatePose x="-2.0" y="-1.0" yaw="0.0" frame_id="map" pose="{goal_pose}" />
          <NavigateToPose goal_pose="{goal_pose}" frame_id="map" goal_topic="/goal_point" timeout_sec="60.0" />

          <CreatePose x="-2.0" y="1.0"  yaw="0.0" frame_id="map" pose="{goal_pose}" />
          <NavigateToPose goal_pose="{goal_pose}" frame_id="map" goal_topic="/goal_point" timeout_sec="60.0" />
        </Sequence>
      </Repeat>
    </Sequence>
  </BehaviorTree>
</root>
