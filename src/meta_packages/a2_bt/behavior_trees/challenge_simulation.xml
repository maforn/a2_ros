<root BTCPP_format="4">
  <!--
    Simulation exploration mission with object detection and home return.
    Same flow as challenge.xml but adapted for sim:
      - FSM boot sequence (stand → balance → walk)
      - No save_map_node (RESPLE MapSaving not present in sim)
      - Sit at the end

    Flow:
      1. SetMode 2/3/4           — boot FSM: stand → unlock → walk
      2. SavePose                — capture robot's current pose from /state_estimation as {home_pose}
      3. OffsetPose + NavigateToPose — move 1 m forward from start position
      4. detection_mapper/start  — reset and start accumulating detections
      5. StartExploration        — trigger ALO via /start_exploration
      6. WaitForExplorationFinish — block until ALO reports done (or timeout)
         (ForceSuccess absorbs timeout so the rest always runs)
      7. StopExploration         — stop ALO waypoints
      8. StopMovement            — halt pathFollower
      9. detection_mapper/stop   — stop accumulating detections
      10. detection_mapper/save_csv — persist detections to CSV
      11. StopMovement(0)        — resume movement for far_planner
      12. NavigateToPose         — return to {home_pose}
      13. detection_mapper/save_csv (second call) — flush detections after nav
      14. SetMode 1              — sit

    Usage:
      a2 bt tree challenge_simulation
  -->
  <BehaviorTree ID="ChallengeSimulation">
    <Sequence>

      <!-- 1. Boot FSM: stand → balance stand → walk -->
      <SetMode mode="2" wait_for_sec="3.0" />
      <SetMode mode="3" wait_for_sec="3.0" />
      <SetMode mode="4" wait_for_sec="1.0" />

      <!-- 2. Capture current pose from /state_estimation as home position -->
      <SavePose pose="{home_pose}" />

      <!-- 3. Move 1 m forward from start position -->
      <OffsetPose input_pose="{home_pose}" distance_x="1.0" output_pose="{forward_pose}" />
      <NavigateToPose
        goal_pose="{forward_pose}"
        frame_id="map"
        goal_topic="/goal_point"
        timeout_sec="30.0" />

      <!-- 5. Reset detection accumulator and start collecting -->
      <CallTriggerService service_name="detection_mapper/start" />

      <!-- 6. Trigger ALO exploration -->
      <StartExploration start_topic="/start_exploration" />

      <!-- 5. Wait for exploration to finish or time out -->
      <ForceSuccess>
        <WaitForExplorationFinish
          finish_topic="exploration_finish"
          status_topic="bt/exploration_status"
          timeout_sec="300.0" />
      </ForceSuccess>

      <!-- 6-7. Stop ALO waypoints and halt pathFollower -->
      <StopExploration />
      <StopMovement />

      <!-- 8-9. Stop detection mapper and persist detections to CSV -->
      <CallTriggerService service_name="detection_mapper/stop" />
      <ForceSuccess>
        <CallTriggerService service_name="detection_mapper/save_csv" />
      </ForceSuccess>

      <!-- 10. Resume movement so far_planner can drive the robot -->
      <StopMovement data="0" />

      <!-- 11. Return home. ForceSuccess absorbs nav failure. -->
      <ForceSuccess>
        <NavigateToPose
          goal_pose="{home_pose}"
          frame_id="map"
          goal_topic="/goal_point"
          timeout_sec="120.0" />
      </ForceSuccess>

      <!-- 12. Final CSV flush after navigation -->
      <ForceSuccess>
        <CallTriggerService service_name="detection_mapper/save_csv" />
      </ForceSuccess>

      <!-- 13. Sit -->
      <SetMode mode="1" wait_for_sec="3.0" />

    </Sequence>
  </BehaviorTree>
</root>
