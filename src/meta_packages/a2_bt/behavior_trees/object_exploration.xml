<root BTCPP_format="4">
  <!--
    Object exploration mission: explore the environment with TARE while the
    detection mapper accumulates YOLO detections into a deduplicated map-frame
    object list with RViz markers.

    Flow:
      1. SetMode 2/3/4         — boot FSM: stand → unlock → walk
      2. SavePose              — capture start position as {home_pose}
      3. CallTriggerService    — start detection mapper (clears previous list)
      4. StartExploration      — trigger TARE via /start_exploration
      5. Parallel              — run exploration alongside a periodic
           WaitForExplorationFinish   CallEmptyService checkpoint (every 30s)
           Repeat/Delay/CallEmptyService  so a crash only loses progress
                                          since the last checkpoint
      6. CallTriggerService    — stop detection mapper
      7. CallEmptyService      — save as soon as exploration finishes
      8. NavigateToPose        — return to {home_pose} (failure/timeout doesn't
                                  block the steps below — map gets saved either way)
      9. CallEmptyService      — save again once home (or once the nav attempt is done)
      10. SetMode 1            — sit

    After the mission, detected objects remain published on
    /detected_objects_markers and logged in the detection_mapper node. The
    map is saved by calling resple's "save_map" service (std_srvs/Empty),
    which writes to the pcd_save_path configured in
    config/resple/params_a2.yaml.

    Usage:
      ros2 action send_goal /bt_action_server behaviortree_ros2/action/ExecuteTree \
        "{target_tree: 'ObjectExploration', payload: 'object_exploration.xml'}"
  -->
  <BehaviorTree ID="ObjectExploration">
    <Sequence>

      <!-- 1. Boot FSM: stand → unlock → walk -->
      <SetMode mode="2" wait_for_sec="3.0" />
      <SetMode mode="3" wait_for_sec="3.0" />
      <SetMode mode="4" wait_for_sec="1.0" />

      <!-- 2. Save starting position before exploring -->
      <!-- <SavePose
        pose_topic="dlio/odom_node/pose"
        timeout_sec="5.0"
        pose="{home_pose}" /> -->
       <CreatePose x="-10.0"  y="0.0"  yaw="0.0" frame_id="map" pose="{home_pose}" />


      <!-- 4. Start detection mapper (resets accumulated object list) -->
      <CallTriggerService service_name="detection_mapper/start" />

      <!-- 5. Trigger TARE exploration -->
      <StartExploration start_topic="/start_exploration" />

      <!-- 5. Wait for exploration to finish or time out, while periodically
           checkpointing the map every 30s in case of a crash.
           ForceSuccess absorbs FAILURE (timeout) so the Sequence always
           continues to the stop + home steps. The Parallel halts the
           Repeat/Delay/CallEmptyService branch as soon as exploration
           completes. -->
      <ForceSuccess>
        <Parallel success_count="1" failure_count="1">

          <WaitForExplorationFinish
            finish_topic="exploration_finish"
            status_topic="bt/exploration_status"
            timeout_sec="10.0" />

          <!-- <Repeat num_cycles="-1">
            <Delay delay_msec="30000">
              <ForceSuccess>
                <CallEmptyService service_name="save_map_node" />
              </ForceSuccess>
            </Delay>
          </Repeat> -->

        </Parallel>
      </ForceSuccess>

      <!-- 6. Stop TARE waypoints and halt pathFollower -->
      <StopExploration />
      <StopMovement />

      <!-- 7. Stop detection mapper -->
      <CallTriggerService service_name="detection_mapper/stop" />

      <!-- 7. Save as soon as exploration finishes, before attempting the
           trip home — ForceSuccess so a save hiccup doesn't block
           navigation/sit below. -->
      <ForceSuccess>
        <CallEmptyService service_name="save_map_node" />
      </ForceSuccess>

      <!-- 8. Resume movement so far_planner can drive the robot -->
      <StopMovement data="0" />

      <!-- 9. Return home. ForceSuccess absorbs FAILURE (e.g. nav timeout) so
           the map still gets saved and the robot still sits down below
           even if it couldn't make it back to {home_pose}. -->
      <ForceSuccess>
        <NavigateToPose
          goal_pose="{home_pose}"
          frame_id="map"
          goal_topic="/goal_point"
          timeout_sec="120.0" />
      </ForceSuccess>

      <!-- 10. Save again once home (or once the nav attempt is done) -->
      <CallEmptyService service_name="save_map_node" />

      <!-- 11. Sit -->
      <SetMode mode="1" wait_for_sec="3.0" />

    </Sequence>
  </BehaviorTree>
</root>
